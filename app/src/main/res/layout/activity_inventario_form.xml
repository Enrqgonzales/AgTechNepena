<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nuevo Item de Inventario"
            android:textSize="?attr/textSizeTitle"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingrese los datos del producto"
            android:textSize="?attr/textSizeBody"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Nombre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del item *"
                android:textSize="?attr/textSizeBody"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_nombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej: Fertilizante NPK"
                android:inputType="text"
                android:background="@drawable/bg_chip_inactive"
                android:padding="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Parcela -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Parcela *"
                android:textSize="?attr/textSizeBody"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner_parcela"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_inactive"
                android:padding="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Categoría -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categoría *"
                android:textSize="?attr/textSizeBody"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner_categoria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_inactive"
                android:padding="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Cantidad y Unidad -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cantidad *"
                        android:textSize="14sp"
                        android:textColor="@color/primary_text"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_cantidad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ej: 10"
                        android:inputType="numberDecimal"
                        android:background="@drawable/bg_chip_inactive"
                        android:padding="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unidad *"
                        android:textSize="14sp"
                        android:textColor="@color/primary_text"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinner_unidad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_inactive"
                        android:padding="16dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Costo Unitario -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Costo unitario (S/) *"
                android:textSize="14sp"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_costo_unitario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej: 25.50"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_chip_inactive"
                android:padding="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Descripción -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción (opcional)"
                android:textSize="14sp"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_descripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Notas adicionales..."
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:background="@drawable/bg_chip_inactive"
                android:padding="16dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Botones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp">

        <Button
            android:id="@+id/btn_cancelar"
            style="@style/Widget.AgTech.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancelar"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_guardar"
            style="@style/Widget.AgTech.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Guardar"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
