<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Attrs for responsive text sizing -->
    <declare-styleable name="AgTechTheme">
        <attr name="textSizeTitle" format="dimension" />
        <attr name="textSizeBody" format="dimension" />
        <attr name="textSizeLabel" format="dimension" />
    </declare-styleable>

    <!-- ═══════════════════════════════════════════════ -->
    <!-- Tema principal MD3 — AgTech Nepeña             -->
    <!-- ═══════════════════════════════════════════════ -->
    <style name="Theme.AgTechNepenya" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/md3_primary</item>
        <item name="colorOnPrimary">@color/md3_on_primary</item>
        <item name="colorPrimaryContainer">@color/md3_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/md3_on_primary_container</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/md3_secondary</item>
        <item name="colorOnSecondary">@color/md3_on_secondary</item>
        <item name="colorSecondaryContainer">@color/md3_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/md3_on_secondary_container</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/md3_tertiary</item>
        <item name="colorOnTertiary">@color/md3_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/md3_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/md3_on_tertiary_container</item>

        <!-- Error -->
        <item name="colorError">@color/md3_error</item>
        <item name="colorOnError">@color/md3_on_error</item>
        <item name="colorErrorContainer">@color/md3_error_container</item>
        <item name="colorOnErrorContainer">@color/md3_on_error_container</item>

        <!-- Surface & Background -->
        <item name="android:colorBackground">@color/md3_background</item>
        <item name="colorOnBackground">@color/md3_on_background</item>
        <item name="colorSurface">@color/md3_surface</item>
        <item name="colorOnSurface">@color/md3_on_surface</item>
        <item name="colorSurfaceVariant">@color/md3_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/md3_on_surface_variant</item>
        <item name="colorSurfaceContainerLowest">@color/md3_surface_container_lowest</item>
        <item name="colorSurfaceContainerLow">@color/md3_surface_container_low</item>
        <item name="colorSurfaceContainer">@color/md3_surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/md3_surface_container_high</item>
        <item name="colorSurfaceContainerHighest">@color/md3_surface_container_highest</item>

        <!-- Outline -->
        <item name="colorOutline">@color/md3_outline</item>
        <item name="colorOutlineVariant">@color/md3_outline_variant</item>

        <!-- Background compat -->
        <item name="android:windowBackground">@color/md3_background</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/md3_background</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/md3_surface_container</item>

        <!-- Responsive text sizes -->
        <item name="textSizeTitle">22sp</item>
        <item name="textSizeBody">16sp</item>
        <item name="textSizeLabel">12sp</item>

        <!-- Component Styles -->
        <item name="materialButtonStyle">@style/Widget.AgTech.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.AgTech.BottomNav</item>
        <item name="materialCardViewStyle">@style/Widget.AgTech.Card</item>
        <item name="tabStyle">@style/Widget.AgTech.TabLayout</item>
    </style>

    <!-- ═══════════════════════════════════ -->
    <!-- Component Styles                   -->
    <!-- ═══════════════════════════════════ -->

    <!-- Botón principal MD3 -->
    <style name="Widget.AgTech.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">28dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
    </style>

    <!-- Botón outline MD3 -->
    <style name="Widget.AgTech.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">28dp</item>
    </style>

    <!-- Botón Activar PIN: texto blanco para contraste en Modo Claro -->
    <!-- SOLO en values/themes.xml (no en values-night) para no afectar el Modo Oscuro -->
    <style name="Widget.AgTech.Button.PinActivar" parent="Widget.AgTech.Button">
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <!-- Card MD3 -->
    <style name="Widget.AgTech.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerLow</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- BottomNav MD3 -->
    <style name="Widget.AgTech.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">?attr/colorSurfaceContainer</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.AgTech.BottomNav.ActiveIndicator</item>
    </style>

    <!-- BottomNav active pill -->
    <style name="Widget.AgTech.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/md3_secondary_container</item>
    </style>

    <!-- TabLayout MD3 -->
    <style name="Widget.AgTech.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">?attr/colorPrimary</item>
        <item name="tabSelectedTextColor">?attr/colorPrimary</item>
        <item name="tabTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabIndicatorFullWidth">false</item>
    </style>

    <!-- SeekBar -->
    <style name="Widget.AgTech.SeekBar" parent="Widget.AppCompat.SeekBar">
        <item name="android:progressTint">?attr/colorPrimary</item>
        <item name="android:thumbTint">?attr/colorPrimary</item>
    </style>

    <!-- Switch MD3 -->
    <style name="Widget.AgTech.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
    </style>
</resources>
